# ============================================
# متغيرات البيئة — مناحل ريف وصاب
# انسخ هذا الملف إلى .env وعدّل القيم. لا ترفع .env إلى Git.
# ============================================
# للإطلاق الفعلي (إنتاج): ضع NODE_ENV=production وعدّل MONGODB_URI و FRONTEND_URL و JWT_* و ADMIN_PASSWORD (انظر DEPLOYMENT.md)
# ============================================

# البيئة: development | production (استخدم production عند النشر)
NODE_ENV=development

# المنفذ (غيّره إن كان منفذك مختلفاً)
PORT=3000

# عنوان الموقع (إلزامي في الإنتاج: ضع رابط موقعك الحقيقي لـ CORS والروابط)
# تطوير: http://localhost:3000  أو  http://localhost:3001
# إنتاج: https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# --- قاعدة البيانات (مطلوب) ---
# تطوير محلي: mongodb://localhost:27017/manahl-badr
# إنتاج: استخدم MongoDB Atlas أو أي استضافة — الصق الرابط من لوحة التحكم
MONGODB_URI=mongodb://localhost:27017/manahl-badr

# JWT (استخدم سلاسل عشوائية طويلة في الإنتاج)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this

# --- حساب المشرف الأول (يُنشأ عند أول تشغيل) ---
# في الإنتاج غيّر كلمة المرور فوراً
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@manahlbadr.com
ADMIN_PASSWORD=ChangeThisPassword123!

# --- اختياري ---
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d
BCRYPT_ROUNDS=12
# حد الطلبات لكل نافذة (900000 = 15 دقيقة). للإطلاق مع عدد كبير من المستخدمين استخدم 1000 أو أكثر
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads

# WebAuthn (للبصمة)
RP_ID=localhost

# البريد (إن وُجد)
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_USER=
# EMAIL_PASS=

# Redis (إن وُجد)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
