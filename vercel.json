{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "DISABLE_CACHE": "1",
    "FORCE_REBUILD": "1"
  },
  "functions": {
    "server.js": {
      "maxDuration": 30
    }
  }
}